# ─────────────────────────────────────────────
#  RL FinTax — Environment Variables
#  Copy this file to .env and fill in values
#  NEVER commit .env to Git
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Your Website URL (for CORS) ─────────────
# Change to your actual domain after deployment
ALLOWED_ORIGIN=http://127.0.0.1:5500

# ── Gmail SMTP Credentials ──────────────────
# Use your Gmail address
GMAIL_USER=fintaxnow24@gmail.com

# IMPORTANT: Use a Gmail App Password, NOT your regular password
# How to get App Password:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (must be ON)
#   3. Security → App Passwords
#   4. Select app: Mail, device: Other → type "RL FinTax"
#   5. Copy the 16-character password here (no spaces)
GMAIL_APP_PASSWORD=otly ndqa mwaf frvc

# ── Email Recipients ────────────────────────
# Primary inbox — all leads land here
TO_EMAIL=fintaxnow24@gmail.com

# Optional: send a copy to a second email (leave blank to skip)
CC_EMAIL=

# ── Auto-Reply to Clients ───────────────────
# Set to true to send a thank-you email to every client who submits the form
SEND_AUTO_REPLY=true

# Your firm name shown in auto-reply
FIRM_NAME=RL FinTax
FIRM_PHONE=+91 7666975881
FIRM_WHATSAPP=https://wa.me/917666975881
